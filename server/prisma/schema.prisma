generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum Role {
  STUDENT
  FACULTY
  ADMIN
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PostCategory {
  ACADEMIC
  EVENTS
  GENERAL
}

enum TargetAudience {
  ALL
  SPECIFIC_DEPT
  SPECIFIC_BATCH
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  firstName     String
  lastName      String
  role          Role     @default(STUDENT)
  departmentId  String?
  batchYear     Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile             Profile?
  timetables          Timetable[]     @relation("FacultyTimetable")
  leaveRequests       LeaveRequest[]  @relation("StudentLeaves")
  reviewedLeaves      LeaveRequest[]  @relation("ReviewedLeaves")
  forumPosts          ForumPost[]
  forumComments       ForumComment[]
  announcements       Announcement[]
}

model Profile {
  id                   String   @id @default(uuid())
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId               String   @unique
  attendancePercentage Float    @default(0.0)
  currentCgpa          Float    @default(0.0)
  enrollmentNumber     String   @unique
}

model Timetable {
  id           String @id @default(uuid())
  departmentId String
  batchYear    Int
  dayOfWeek    Int    // 1 (Monday) to 5 (Friday)
  periodNumber Int
  subjectName  String
  faculty      User   @relation("FacultyTimetable", fields: [facultyId], references: [id])
  facultyId    String
  roomNumber   String
}

model LeaveRequest {
  id          String      @id @default(uuid())
  student     User        @relation("StudentLeaves", fields: [studentId], references: [id])
  studentId   String
  startDate   DateTime
  endDate     DateTime
  reason      String
  documentUrl String?
  status      LeaveStatus @default(PENDING)
  reviewedBy  User?       @relation("ReviewedLeaves", fields: [reviewedById], references: [id])
  reviewedById String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model ForumPost {
  id        String       @id @default(uuid())
  author    User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String
  title     String
  contentMd String
  category  PostCategory
  upvotes   Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  comments  ForumComment[]
}

model ForumComment {
  id        String    @id @default(uuid())
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String
  content   String
  createdAt DateTime  @default(now())
}

model Announcement {
  id             String         @id @default(uuid())
  author         User           @relation(fields: [authorId], references: [id])
  authorId       String
  title          String
  content        String
  targetAudience TargetAudience
  isPinned       Boolean        @default(false)
  createdAt      DateTime       @default(now())
}
